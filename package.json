{
  "name": "storyai-3d-director-desk-demo",
  "productName": "AI影视导演台",
  "version": "0.9.0",
  "description": "Local-first AI 3D director desk with multi-phone camera control, character animation, scene scripting, and smooth video export.",
  "author": "femnn",
  "license": "MIT",
  "type": "module",
  "main": "desktop/main.mjs",
  "keywords": [
    "3d",
    "director",
    "threejs",
    "react-three-fiber",
    "vite",
    "storyboard",
    "virtual-camera",
    "previs",
    "ai-filmmaking"
  ],
  "scripts": {
    "dev": "node server/dev-server.mjs",
    "dev:http": "node server/dev-server.mjs --no-https",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "desktop": "npm run build && electron .",
    "package:mac": "node scripts/prepare-desktop-binaries.mjs --platform=darwin && npm run build && electron-builder --mac --publish never",
    "package:win": "node scripts/prepare-desktop-binaries.mjs --platform=win32 && npm run build && electron-builder --win --publish never",
    "package:all": "npm run build && electron-builder --mac --win",
    "test": "vitest run",
    "preview": "vite preview",
    "prepare-mocap-assets": "node scripts/prepare-mediapipe-assets.mjs",
    "postinstall": "node scripts/prepare-mediapipe-assets.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@mediapipe/tasks-vision": "0.10.17",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.14",
    "camera-controls": "^2.9.0",
    "lucide-react": "^0.469.0",
    "pinyin-pro": "^3.28.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.0.1",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.storyai.directordesk",
    "artifactName": "AI-Director-Desk-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "server/dev-server.mjs",
      "server/websocket-frames.mjs",
      "server/video-transcode.mjs",
      "package.json"
    ],
    "asar": false,
    "mac": {
      "category": "public.app-category.video",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "extraResources": [
        {
          "from": "tools/desktop-bin/cloudflared-darwin-arm64",
          "to": "bin/cloudflared"
        },
        {
          "from": "tools/desktop-bin/ffmpeg-darwin-arm64",
          "to": "bin/ffmpeg"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "extraResources": [
        {
          "from": "tools/desktop-bin/cloudflared-windows-x64.exe",
          "to": "bin/cloudflared.exe"
        },
        {
          "from": "tools/desktop-bin/ffmpeg-windows-x64.exe",
          "to": "bin/ffmpeg.exe"
        }
      ]
    },
    "nsis": {
      "artifactName": "AI-Director-Desk-${version}-Windows-${arch}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "AI-Director-Desk-${version}-Windows-${arch}-Portable.${ext}"
    }
  }
}
